# Variables de Entorno para Microservicio de Productos
# Copia este archivo a .env y completa los valores reales

PORT=10102
DB_HOST=localhost
DB_USERNAME=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_DATABASE=microservice_product
DB_PORT=3306
DB_SSL=false
# CONFIGURACIÓN DE AUTENTICACIÓN (TEMPORALMENTE DESHABILITADA)
# JWT_SECRET=tu_secreto_jwt
# USUARIOS_SERVICE_URL=http://localhost:puerto-del-servicio-usuarios/api/users/
# CONFIGURACIÓN DE AZURE STORAGE (IMÁGENES)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=tu_cuenta_azure;AccountKey=tu_key_azure;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=productos

NODE_ENV=development

