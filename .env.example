# Variables de Entorno para Microservicio de Productos
# Copia este archivo a .env y completa los valores reales

PORT=tu_puerto
DB_HOST=tu_db_host
DB_USERNAME=tu_db_username
DB_PASSWORD=tu_db_password
DB_DATABASE=tu_db_name
DB_PORT=tu_db_port
DB_SSL=false

#Variables de Supabase
#Variables de Supabase
SUPABASE_URL=tu_supabase_url
SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=tu_supabase_storage_bucket

# Configuración de base de datos PostgreSQL de Supabase
DATABASE_URL=tu_database_url
DB_HOST=tu_db_host
DB_PORT=tu_db_port
DB_DATABASE=tu_db_name
DB_USERNAME=tu_db_username
DB_PASSWORD=tu_db_password
DB_SSL=true

# CONFIGURACIÓN DE AUTENTICACIÓN (TEMPORALMENTE DESHABILITADA)
# JWT_SECRET=tu_secreto_jwt
# USUARIOS_SERVICE_URL=http://localhost:puerto-del-servicio-usuarios/api/users/

NODE_ENV=development
